# Copy this to bot.env and fill in your real values.
# bot.env is gitignored; never commit your real tokens.

# --- Telegram (recommended channel for alerts) ---
TELEGRAM_BOT_TOKEN=replace_with_token_from_BotFather
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# --- Loop settings (optional) ---
# Bot config (audited defaults: 4h kline, 30-min poll, momentum mode).
INTERVAL_MINUTES=30
KLINE=4h
MODE=auto

# --- Optional: email / SMS gateway alerts ---
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=you@gmail.com
# SMTP_PASS=app_password_here
# SMTP_PORT=587
# SMTP_SSL=0
# ALERT_FROM=you@gmail.com
# ALERT_TO=you@gmail.com,5555551234@tmomail.net

# --- Optional: CoinMarketCap fallback source ---
# CMC_API_KEY=your_cmc_api_key
